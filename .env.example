# =============================================================================
# Agury Platform — Environment Variables
# =============================================================================
# Copy this to .env and fill in the values

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://agury:agury123@localhost:5432/agury_platform?schema=public"

# Segredo JWT (gere com: openssl rand -base64 48)
JWT_SECRET="troque-por-um-segredo-forte-de-pelo-menos-32-caracteres"

# Segredo de sessão (gere com: openssl rand -base64 48)
SESSION_SECRET="outro-segredo-forte-de-pelo-menos-32-caracteres-aqui"

# URL pública
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Agury Auto"

# Ambiente
NODE_ENV="development"

# Email — descomente e preencha o provider desejado
# EMAIL_FROM="noreply@agury.com.br"
# RESEND_API_KEY=""
# SENDGRID_API_KEY=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"

# Pagamentos — descomente quando ativar
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PUBLISHABLE_KEY=""
# MERCADOPAGO_ACCESS_TOKEN=""
# MERCADOPAGO_WEBHOOK_SECRET=""

# Afiliados
AFFILIATE_DEFAULT_COMMISSION="10"
AFFILIATE_COOKIE_DAYS="30"
