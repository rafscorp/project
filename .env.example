# =============================================================================
# Agury Platform — Environment Variables
# =============================================================================
# Copy this to .env and fill in the values

# =============================================================================
# Agury Platform — Environment Variables
# =============================================================================
# Copy this to .env and fill in the values

# Banco de dados PostgreSQL (container docker)
DB_USER=agury
DB_PASSWORD=troque-esta-senha
DB_NAME=agury_platform
DATABASE_URL="postgresql://agury:troque-esta-senha@postgres:5432/agury_platform?schema=public"

# Segredos JWT e sessão (gere com: openssl rand -base64 48)
JWT_SECRET="troque-por-um-segredo-forte-de-pelo-menos-32-caracteres"
SESSION_SECRET="outro-segredo-forte-de-pelo-menos-32-caracteres-aqui"

# URL pública
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Agury Auto"

# Ambiente
NODE_ENV="production"

# Email — Resend
EMAIL_FROM="noreply@agury.com.br"
RESEND_API_KEY=""

# Pagamentos — opcional
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Afiliados
AFFILIATE_DEFAULT_COMMISSION="10"
AFFILIATE_COOKIE_DAYS="30"
